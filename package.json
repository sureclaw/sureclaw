{
  "name": "ax",
  "version": "0.1.0",
  "description": "Security-first personal AI agent",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "ax": "bin/ax.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:admin": "npm --prefix ui/admin run build",
    "build:chat": "npm --prefix ui/chat run build",
    "build:ui": "npm run build:admin && npm run build:chat",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fuzz": "vitest run tests/ipc-fuzz.test.ts",
    "serve": "NODE_NO_WARNINGS=1 tsx src/cli/index.ts serve",
    "send": "NODE_NO_WARNINGS=1 tsx src/cli/index.ts send",
    "configure": "NODE_NO_WARNINGS=1 tsx src/cli/index.ts configure",
    "dev:chat": "bash scripts/chat-dev.sh",
    "k8s:dev": "bash scripts/k8s-dev.sh",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "security",
    "sandbox"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@anthropic-ai/sdk": "^0.91.1",
    "@apidevtools/swagger-parser": "^12.1.0",
    "@google-cloud/storage": "^7.19.0",
    "@inquirer/prompts": "^8.4.2",
    "@kubernetes/client-node": "^1.4.0",
    "@mariozechner/pi-agent-core": "0.70.2",
    "@mariozechner/pi-ai": "0.70.2",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@sinclair/typebox": "^0.34.49",
    "@slack/bolt": "^4.7.1",
    "@tavily/core": "^0.7.2",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "highlight.js": "^11.11.1",
    "kysely": "^0.28.16",
    "marked": "^18.0.2",
    "node-forge": "^1.4.0",
    "openai": "^6.34.0",
    "openapi-types": "^12.1.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sqlite-vec": "^0.1.9",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "minimatch": ">=10.2.3",
    "glob": ">=11.0.0",
    "fast-xml-parser": ">=5.7.0",
    "uuid": ">=14.0.0",
    "rollup": ">=4.59.0",
    "hono": ">=4.12.2",
    "basic-ftp": ">=5.3.0",
    "sqlite-vec-linux-arm64": "0.1.7-alpha.2",
    "@tootallnate/once": ">=3.0.1",
    "yauzl": ">=3.2.1"
  }
}
