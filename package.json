{
  "name": "ax",
  "version": "0.1.0",
  "description": "Security-first personal AI agent",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "ax": "bin/ax.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:dashboard": "cd ui/dashboard && npm install && npm run build",
    "build:chat": "cd ui/chat && npm install && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fuzz": "vitest run tests/ipc-fuzz.test.ts",
    "serve": "NODE_NO_WARNINGS=1 tsx src/cli/index.ts serve",
    "send": "NODE_NO_WARNINGS=1 tsx src/cli/index.ts send",
    "configure": "NODE_NO_WARNINGS=1 tsx src/cli/index.ts configure",
    "k8s:dev": "bash scripts/k8s-dev.sh",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "security",
    "sandbox"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google-cloud/storage": "^7.19.0",
    "@inquirer/prompts": "^8.3.0",
    "@kubernetes/client-node": "^1.4.0",
    "@mariozechner/pi-agent-core": "^0.58.1",
    "@mariozechner/pi-ai": "^0.58.1",
    "@mariozechner/pi-coding-agent": "^0.58.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@sinclair/typebox": "^0.34.48",
    "@slack/bolt": "^4.6.0",
    "@tavily/core": "^0.7.2",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "highlight.js": "^11.11.1",
    "keytar": "^7.9.0",
    "kysely": "^0.28.14",
    "marked": "^17.0.4",
    "nats": "^2.29.3",
    "node-forge": "^1.3.3",
    "openai": "^6.29.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sqlite-vec": "^0.1.6",
    "strip-ansi": "^7.2.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.18.0",
    "fast-check": "^4.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "minimatch": ">=10.2.3",
    "glob": ">=11.0.0",
    "fast-xml-parser": ">=5.5.7",
    "rollup": ">=4.59.0",
    "hono": ">=4.12.2",
    "basic-ftp": ">=5.2.0",
    "sqlite-vec-linux-arm64": "0.1.7-alpha.2",
    "@tootallnate/once": ">=3.0.1",
    "yauzl": ">=3.2.1"
  }
}
